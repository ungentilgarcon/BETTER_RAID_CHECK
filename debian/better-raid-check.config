#!/bin/sh
set -e

. /usr/share/debconf/confmodule
db_version 2.0 || true

is_non_negative_int() {
  case "$1" in
    ''|*[!0-9]*) return 1 ;;
    *) return 0 ;;
  esac
}

is_positive_int() {
  case "$1" in
    ''|0|*[!0-9]*) return 1 ;;
    *) return 0 ;;
  esac
}

is_interval_spec() {
  case "$1" in
    *d|*M) ;;
    *) return 1 ;;
  esac
  count=${1%[dM]}
  is_positive_int "$count"
}

interval_over_risk_threshold() {
  interval="$1"
  count=${interval%[dM]}
  unit=${interval#${interval%?}}

  if [ "$unit" = "M" ] && [ "$count" -gt 2 ]; then
    return 0
  fi

  if [ "$unit" = "d" ] && [ "$count" -gt 60 ]; then
    return 0
  fi

  return 1
}

bool_from_zero_one() {
  if [ "$1" = "1" ]; then
    printf '%s\n' true
  else
    printf '%s\n' false
  fi
}

get_cfg_value() {
  key="$1"
  cfg="/etc/default/raid-check-serial"
  [ -r "$cfg" ] || return 1
  sed -n "s/^${key}=//p" "$cfg" | tail -n 1 | tr -d '[:space:]'
}

seed_from_existing_config() {
  val="$(get_cfg_value MAX_HDD_CONCURRENT || true)"
  [ -n "$val" ] && db_set better-raid-check/hdd_limit "$val" || true

  val="$(get_cfg_value MAX_SSD_CONCURRENT || true)"
  [ -n "$val" ] && db_set better-raid-check/ssd_limit "$val" || true

  val="$(get_cfg_value MAX_NVM_CONCURRENT || true)"
  [ -n "$val" ] && db_set better-raid-check/nvm_limit "$val" || true

  val="$(get_cfg_value MERGE_SSD_NVM_CLASSES || true)"
  [ -n "$val" ] && db_set better-raid-check/merge_ssd_nvm "$(bool_from_zero_one "$val")" || true

  val="$(get_cfg_value SLEEP_SECS || true)"
  [ -n "$val" ] && db_set better-raid-check/sleep_secs "$val" || true

  val="$(get_cfg_value DRY_RUN || true)"
  [ -n "$val" ] && db_set better-raid-check/dry_run "$(bool_from_zero_one "$val")" || true

  override="/etc/systemd/system/raid-check-serial.timer.d/override.conf"
  if [ -r "$override" ]; then
    val="$(sed -n 's/^OnUnitActiveSec=//p' "$override" | tail -n 1 | tr -d '[:space:]')"
    case "$val" in
      *d) db_set better-raid-check/check_interval "$val" || true ;;
    esac
  fi
}

sanitize_values() {
  db_get better-raid-check/check_interval
  if ! is_interval_spec "$RET"; then
    db_set better-raid-check/check_interval 1M || true
  fi

  db_get better-raid-check/hdd_limit
  if ! is_non_negative_int "$RET"; then
    db_set better-raid-check/hdd_limit 1 || true
  fi

  db_get better-raid-check/ssd_limit
  if ! is_non_negative_int "$RET"; then
    db_set better-raid-check/ssd_limit 1 || true
  fi

  db_get better-raid-check/nvm_limit
  if ! is_non_negative_int "$RET"; then
    db_set better-raid-check/nvm_limit 1 || true
  fi

  db_get better-raid-check/sleep_secs
  if ! is_positive_int "$RET"; then
    db_set better-raid-check/sleep_secs 20 || true
  fi
}

should_prompt=0
if [ "${DEBIAN_FRONTEND:-}" != "noninteractive" ]; then
  if [ "$1" = "reconfigure" ]; then
    should_prompt=1
  elif [ "$1" = "configure" ] && [ -z "${2:-}" ]; then
    should_prompt=1
  fi
fi

seed_from_existing_config
sanitize_values

if [ "$should_prompt" -eq 1 ]; then
  while true; do
    db_fset better-raid-check/check_interval seen false || true
    db_fset better-raid-check/hdd_limit seen false || true
    db_fset better-raid-check/ssd_limit seen false || true
    db_fset better-raid-check/nvm_limit seen false || true
    db_fset better-raid-check/merge_ssd_nvm seen false || true
    db_fset better-raid-check/sleep_secs seen false || true
    db_fset better-raid-check/dry_run seen false || true
    db_fset better-raid-check/disable_conflicts seen false || true
    db_fset better-raid-check/start_now seen false || true

    db_input medium better-raid-check/check_interval || true
    db_input medium better-raid-check/hdd_limit || true
    db_input medium better-raid-check/ssd_limit || true
    db_input medium better-raid-check/nvm_limit || true
    db_input medium better-raid-check/merge_ssd_nvm || true
    db_input medium better-raid-check/sleep_secs || true
    db_input medium better-raid-check/dry_run || true
    db_input medium better-raid-check/disable_conflicts || true
    db_input low better-raid-check/start_now || true
    db_go || true

    sanitize_values

    db_get better-raid-check/check_interval
    if interval_over_risk_threshold "$RET"; then
      db_set better-raid-check/interval_risk_confirm false || true
      db_fset better-raid-check/interval_risk_confirm seen false || true
      db_input high better-raid-check/interval_risk_confirm || true
      db_go || true
      db_get better-raid-check/interval_risk_confirm
      if [ "$RET" != "true" ]; then
        continue
      fi
    fi

    break
  done
fi

db_stop
exit 0
